# Database – Neon PostgreSQL serverless connection string
# Získáš ho v Neon console: Settings → Connection string (pooler URL pro Node.js)
# Formát: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example-123.eu-central-1.aws.neon.tech/chleba?sslmode=require

# Resend API klíč pro odesílání emailů
# Získáš ho na https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin token – tajný token pro přístup do admin rozhraní
# Vygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# URL pro admin přístup bude: https://tvoje-domena.vercel.app/admin/<ADMIN_TOKEN>
ADMIN_TOKEN=64znakovy_hex_string_zde

# Cron secret – Vercel automaticky posílá tento token v Authorization headeru pro cron joby
# Nastav stejnou hodnotu v Vercel dashboard: Settings → Environment Variables
# Vygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=64znakovy_hex_string_pro_cron_zde

# Odesílatel emailů – musí být ověřená doména v Resend (resend.com/domains)
# Příklad: chleba@tvoje-domena.cz
EMAIL_FROM=chleba@tvoje-domena.cz

# Admin email – adresa, na kterou se posílá týdenní soupiska objednávek
ADMIN_EMAIL=chleba.zupacrew@gmail.com

# Veřejná URL aplikace – používá se pro generování odkazů v emailech z cron kontextu
# Formát: https://tvoje-domena.vercel.app (bez trailing slash)
NEXT_PUBLIC_APP_URL=https://chleba-objednavky.vercel.app
